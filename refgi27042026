#extension GL_EXT_samplerless_texture_functions : enable
#endif

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

#define M_PI 3.141592
#define M_TAU 6.283185
#define SDFGI_MAX_CASCADES 8

#define MAX_TRACE_ITERATIONS 192
#define GLOSSY_SAMPLES 6
#define MIRROR_ROUGHNESS_THRESHOLD 0.18
#define TRACE_TO_PROBE_BLEND_START 0.35
#define TRACE_TO_PROBE_BLEND_END 0.65
#define VCT_DIFFUSE_CONES_HQ 14
#define VCT_GLOSSY_CONES 6
#define SDF_CONE_NARROWNESS 0.20
#define LIGHT_LOD_BIAS -0.5

